{
  "name": "prathamesh-patil-portfolio",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "description": "Prathamesh Patil — Fullstack Engineer portfolio",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-server && node scripts/prerender.mjs",
    "build:spa": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "complexity": "eslint -c eslint.complexity.config.js .",
    "verify": "npm run typecheck && npm run lint && npm run complexity",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "eslint -c eslint.complexity.config.js"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.11"
  }
}
